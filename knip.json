{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/cli.ts",
    "src/plugin-api.ts",
    "src/plugin-api/unstable.ts",
    "extensions/pi-web.ts",
    "pi-web-plugins/**/pi-web-plugin.ts",
    "scripts/*.mjs"
  ],
  "project": [
    "src/**/*.ts",
    "extensions/**/*.ts",
    "pi-web-plugins/**/*.ts"
  ],
  "ignoreBinaries": ["changeset", "eslint", "knip", "tsc", "tsx", "vite", "vitest"],
  "ignoreDependencies": ["tsx"],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "src/config.ts": ["exports"]
  }
}
